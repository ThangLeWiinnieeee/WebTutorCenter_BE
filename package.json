{
  "name": "webtutorcenter-client-be",
  "version": "1.0.0",
  "description": "WebTutorCenter Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "seed:users": "node -r ./scripts/_atlasDns.js scripts/seedDemoData.js users",
    "seed:tutors": "node -r ./scripts/_atlasDns.js scripts/seedDemoData.js tutors",
    "seed:schools": "node -r ./scripts/_atlasDns.js scripts/seedSchools.js",
    "seed:demo": "node -r ./scripts/_atlasDns.js scripts/seedDemoData.js all",
    "dev": "nodemon server.js",
    "seed:locations": "node -r ./scripts/_atlasDns.js scripts/seedLocations.js",
    "seed:subjects": "node -r ./scripts/_atlasDns.js scripts/seedSubjects.js",
    "seed:classes": "node -r ./scripts/_atlasDns.js scripts/seedClasses.js",
    "seed:update-tutor-fields": "node -r ./scripts/_atlasDns.js scripts/seedUpdateTutorFields.js",
    "seed:lookups": "node -r ./scripts/_atlasDns.js scripts/seedLookups.js",
    "seed:tutor-demo": "node -r ./scripts/_atlasDns.js scripts/seedTutorDemoData.js",
    "seed:pricing": "node -r ./scripts/_atlasDns.js scripts/seedClassPricing.js",
    "seed:full": "node -r ./scripts/_atlasDns.js scripts/seedFullDemo.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.12.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
