# ─────────────── Server ───────────────
PORT=5002
# Đặt "production" khi deploy lên Render (bật Secure + SameSite=Lax cho cookie)
NODE_ENV=development

# Nhiều origin phân tách bằng dấu phẩy. Khi deploy thêm domain FE trên Vercel.
# vd: http://localhost:4000,https://app.tenmien.com
CLIENT_URL=http://localhost:4000

# Chỉ đặt khi FE + BE cùng domain cha (app.tenmien.com ↔ api.tenmien.com).
# Giá trị bắt đầu bằng dấu chấm để cookie refresh dùng chung mọi subdomain.
# vd: .tenmien.com   — bỏ trống ở localhost.
COOKIE_DOMAIN=

# ─────────────── Database ───────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# ─────────────── JWT ───────────────
ACCESS_TOKEN_SECRET=your-access-token-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ─────────────── Google OAuth ───────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────── Email (Gmail API + OAuth2 - HTTPS, không bị host chặn cổng SMTP) ───────────────
# Tài khoản Gmail dùng để gửi (phải là tài khoản đã cấp quyền khi lấy refresh token)
GMAIL_USER=your-email@gmail.com
# Lấy bằng: node scripts/getGmailRefreshToken.js (chạy 1 lần)
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
# Tên hiển thị + email gửi (mặc định lấy GMAIL_USER nếu bỏ trống)
EMAIL_FROM=WebTutorCenter <your-email@gmail.com>
# Dùng lại GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET ở mục Google OAuth phía trên

# ─────────────── Cloudinary (upload ảnh) ───────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
